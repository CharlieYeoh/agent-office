# Core model key
ANTHROPIC_API_KEY=sk-ant-...

# Pronote login (required if PRONOTE_TOKEN_JSON is not set)
PRONOTE_URL=https://your-school.index-education.net/pronote/eleve.html
PRONOTE_USERNAME=your-username
PRONOTE_PASSWORD=your-password

# Optional: direct Pronote token credentials JSON (raw JSON string)
# PRONOTE_TOKEN_JSON={"pronote_url":"...","username":"...","password":"...","client_identifier":"...","uuid":""}

# Optional: same value as base64-encoded JSON (easier for dashboards)
# PRONOTE_TOKEN_JSON_B64=<base64-json>

# Google OAuth authorized-user token JSON (from token.json)
# Provide ONE of these:
GOOGLE_TOKEN_JSON={"token":"...","refresh_token":"...","token_uri":"https://oauth2.googleapis.com/token","client_id":"...","client_secret":"...","scopes":["https://www.googleapis.com/auth/gmail.modify","https://www.googleapis.com/auth/drive.readonly"]}
# GOOGLE_TOKEN_JSON_B64=<base64-json>

# Optional subject mapping overrides
# PRONOTE_MATH_SUBJECT=Math Analysis and Approaches HL
# PRONOTE_PHYSICS_SUBJECT=Physics HL
# PRONOTE_CS_SUBJECT=Computer Science
# PRONOTE_ENGLISH_SUBJECT=English Language and Literature SL
# PRONOTE_FRENCH_SUBJECT=French B
# PRONOTE_ECON_SUBJECT=Economics
# PRONOTE_TOK_SUBJECT=Theory of Knowledge
